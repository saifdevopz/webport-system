@page "/item/modify"
@page "/item/modify/{ItemId}"
@attribute [Authorize(Roles = "User")]

<MudCardHeader>
    <CardHeaderContent>
        @if (Id == null)
        {
            <MudText Typo="Typo.h6">Add Item</MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">Update Item</MudText>
        }
    </CardHeaderContent>
</MudCardHeader>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Description">
      
    </MudTabPanel>
    <MudTabPanel Text="Quantity">
        <MudText>Content Two</MudText>

    </MudTabPanel>
