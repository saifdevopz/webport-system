@page "/invoice/index2"
@layout TenantLayout
@attribute [Authorize(Roles = "User")]

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudGrid Spacing="4" Class="align-start">
        <MudItem xs="12">
            <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-3 mb-6">
                <div>
                    <MudText Typo="Typo.h4">Create Invoice</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Professional invoice drafting with instant totals and polished layout.</MudText>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDraft">Save Draft</MudButton>
                </div>
            </div>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudCard Class="pa-2">
                <MudCardContent>
                    <MudForm Model="invoiceViewModel" @ref="form">
                        <MudText Typo="Typo.h6">Invoice Details</MudText>
                        <MudDivider DividerType="DividerType.Middle" Class="my-4" />

                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="invoiceViewModel.InvoiceNumber" Label="Invoice Number" Variant="Variant.Outlined" Required="true" HelperText="Unique billing reference" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker @bind-Date="invoiceViewModel.InvoiceDate" Label="Invoice Date" Variant="Variant.Outlined" PickerVariant="PickerVariant.Dialog" />
                            </MudItem>
                        </MudGrid>

                        <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                        <MudText Typo="Typo.h6">Bill To</MudText>
                        <MudGrid Spacing="3" Class="mt-1">
                            <MudSelect T="CustomerDto" @bind-Value="_selectedCustomer" Label="Select Customer">
                                @foreach (var customer in Customers)
                                {
                                    <MudSelectItem Value="customer">@customer.CustomerName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudGrid>

                        <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                        <MudGrid Spacing="3" Class="mt-1">
                            <MudSelect T="ItemDto" @bind-Value="_selectedItem" Label="Select Item">
                                @foreach (var item in Items)
                                {
                                    <MudSelectItem T="ItemDto" Value="item">@item.ItemDesc</MudSelectItem>
                                }
                            </MudSelect>

                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddSelectedItem">Add Item</MudButton>
                        </MudGrid>

                        <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                        <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-3 mb-3">
                            <MudText Typo="Typo.h6">Line Items</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddItem">Add Item</MudButton>
                        </div>

                        <MudTable T="InvoiceItemDto" Items="invoiceViewModel.Items" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>Description</MudTh>
                                <MudTh>Qty</MudTh>
                                <MudTh>Rate</MudTh>
                                <MudTh>Amount</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Description">
                                    <MudTextField @bind-Value="context.ItemDesc" Label="Description" Variant="Variant.Outlined" Immediate="true" />
                                </MudTd>
                                <MudTd DataLabel="Qty">
                                    <MudNumericField T="decimal" @bind-Value="context.Quantity" Label="Qty" Variant="Variant.Outlined" Min="0" Immediate="true" />
                                </MudTd>
                                <MudTd DataLabel="Rate">
                                    <MudNumericField T="decimal" @bind-Value="context.UnitPrice" Label="Rate" Variant="Variant.Outlined" Min="0" Immediate="true" />
                                </MudTd>
                                <MudTd DataLabel="Amount">
                                    <MudText Typo="Typo.body1">@GetLineTotal(context))</MudText>
                                </MudTd>
                                <MudTd DataLabel="Remove">
                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemoveItem(context))">Remove</MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        <MudGrid Spacing="3" Class="mt-4">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="invoiceViewModel.Notes" Label="Notes / Payment Terms" Variant="Variant.Outlined" Lines="4" HelperText="Visible on the final invoice" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-5 rounded-lg" Elevation="1">
                <MudText Typo="Typo.h6">Invoice Summary</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Live preview of invoice totals.</MudText>

                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body1">Subtotal</MudText>
                    <MudText Typo="Typo.body1">@Subtotal</MudText>
                </div>

                <MudDivider DividerType="DividerType.Middle" Class="my-4" />

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Total Due</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary">@Total)</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <MudCardActions Style="display: flex; justify-content: end; gap: 10px">            
            <MudButton OnClick="SaveInvoice" Variant="Variant.Outlined" Color="Color.Primary">Save</MudButton>
        </MudCardActions>
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public string? Id { get; set; }
    private bool IsEditMode => !string.IsNullOrWhiteSpace(Id);

    private MudForm? form;
    private readonly InvoiceDto invoiceViewModel = new();

    private decimal Subtotal => invoiceViewModel.Items.Sum(GetLineTotal);
    private decimal Total => Math.Max(0, Subtotal);

    private CustomerDto? _selectedCustomer;
    private ItemDto? _selectedItem;

    private List<CustomerDto> Customers = new();
    private List<ItemDto> Items = new();

    protected override async Task OnInitializedAsync()
    {
        var customers = await _DataService.GetAllAsync<CustomerDto>("customer");
        Customers = customers.Data.ToList();

        var items = await _DataService.GetAllAsync<ItemDto>("item");
        Items = items.Data.ToList();
    }

    private void AddSelectedItem()
    {
        if (_selectedItem is null)
            return;

        var existing = invoiceViewModel.Items.FirstOrDefault(x => x.ItemId == _selectedItem.ItemId);

        if (existing != null)
        {
            // 🔥 If already exists → increase quantity
            existing.Quantity += 1;
        }
        else
        {
            invoiceViewModel.Items.Add(new InvoiceItemDto
            {
                ItemId = _selectedItem.ItemId,
                ItemDesc = _selectedItem.ItemDesc,
                Quantity = 1
            });
        }

        _selectedItem = null; // reset dropdown
        RecalculateTotals();
    }

    private void RecalculateTotals()
    {
        foreach (var item in invoiceViewModel.Items)
        {
            item.Total = item.UnitPrice * item.Quantity;
        }

        invoiceViewModel.SubTotal = invoiceViewModel.Items.Sum(i => i.Total);
        invoiceViewModel.Total = invoiceViewModel.SubTotal; // Could add taxes later
    }

    private async Task SaveInvoice()
    {
        if (_selectedCustomer == null)
        {
            await DialogService.ShowMessageBox("Error", "Please select a customer.");
            return;
        }

        invoiceViewModel.CustomerId = _selectedCustomer.CustomerId;

        Result response = IsEditMode
            ? await _DataService.PutAsync("invoice", invoiceViewModel)
            : await _DataService.PostAsync("invoice", invoiceViewModel);

        if (response.IsSuccess)
        {
            await DialogService.ShowMessageBox("Success", "Invoice saved successfully!");
            _NavigationManager.NavigateTo("/invoice/index");
        }
        else
        {
            await DialogService.ShowMessageBox("Error", response.Error?.Description ?? "Unknown error");
        }
    }

    private static decimal GetLineTotal(InvoiceItemDto item)
    {
        return Math.Max(0, item.Quantity * item.UnitPrice);
    }

    private void AddItem()
    {
        invoiceViewModel.Items.Add(new InvoiceItemDto());
    }

    private void RemoveItem(InvoiceItemDto item)
    {
        if (invoiceViewModel.Items.Count <= 1)
            return;

        invoiceViewModel.Items.Remove(item);
    }

    private async Task SaveDraft()
    {
        if (form is not null)
            await form.Validate();
    }

}
