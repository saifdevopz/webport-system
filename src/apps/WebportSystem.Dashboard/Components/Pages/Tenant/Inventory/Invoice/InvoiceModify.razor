@page "/invoice/modify/{Id?}"
@layout TenantLayout
@attribute [Authorize(Roles = "User")]

<MudText Typo="Typo.h6">Invoice</MudText>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudGrid Spacing="4" Class="align-start">
        <MudItem xs="12">
            <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center gap-3 mb-6">
                <div>
                    <MudText Typo="Typo.h4">Create Invoice</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Professional invoice drafting with instant totals and polished layout.</MudText>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary">Reset</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary">Save Draft</MudButton>
                </div>
            </div>
        </MudItem>
    
        <MudItem xs="12" lg="8">
            <MudCard Class="pa-2">
                <MudCardContent>
                    <MudText Typo="Typo.h6">Details</MudText>
                    <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudDatePicker @bind-Date="Invoice.InvoiceDate" Label="Invoice Date" Variant="Variant.Outlined" PickerVariant="PickerVariant.Dialog" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker @bind-Date="Invoice.DueDate" Label="Due Date" Variant="Variant.Outlined" PickerVariant="PickerVariant.Dialog" />
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.h6">Bill to</MudText>
                    <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />
                    <div class="input-container">
                        <MudSelect T="CustomerDto" Variant="Variant.Outlined" @bind-Value="_selectedCustomer" Label="Select Customer">
                            @foreach (var customer in Customers)
                            {
                                <MudSelectItem Value="customer">@customer.CustomerName</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <MudText Typo="Typo.h6">Items</MudText>
                    <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />


                    <div class="input-container">
                        <MudSelect T="ItemDto" Variant="Variant.Outlined" @bind-Value="_selectedItem" SelectedValuesChanged="AddSelectedItem" Label="Select Item">
                            @foreach (var item in Items)
                            {
                                <MudSelectItem T="ItemDto" Value="item">@item.ItemDesc</MudSelectItem>
                            }
                        </MudSelect>                                                  
                    </div>


                    <MudTable T="InvoiceItemDto"
                              Items="@Invoice.Items"
                              Dense="true"
                              Hover="true"
                              Elevation="0">
                        <HeaderContent>
                            <MudTh>Description</MudTh>
                            <MudTh>Qty</MudTh>
                            <MudTh>Rate</MudTh>
                            <MudTh>Amount</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Description">
                                <MudTextField @bind-Value="context.ItemDesc" Label="Description" Variant="Variant.Outlined" Immediate="true" />
                            </MudTd>
                            <MudTd DataLabel="Qty">
                                <MudNumericField T="decimal" @bind-Value="context.Quantity" Label="Qty" Variant="Variant.Outlined" Min="0" Immediate="true" />
                            </MudTd>
                            <MudTd DataLabel="Rate">
                                <MudNumericField T="decimal" @bind-Value="context.UnitPrice" Label="Rate" Variant="Variant.Outlined" Min="0" Immediate="true" />
                            </MudTd>
                            <MudTd DataLabel="Amount">
                                <MudText Typo="Typo.body1">R @GetLineTotal(context)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Remove">                                
                                <MudIconButton OnClick="@(() => RemoveItem(context))" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudGrid Spacing="3" Class="mt-4">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Invoice.Notes" Label="Notes / Payment Terms" Variant="Variant.Outlined" Lines="4" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-5 rounded-lg" Elevation="1">
                <MudText Typo="Typo.h6">Invoice Summary</MudText>             

                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body1">Subtotal</MudText>
                    <MudText Typo="Typo.body1">R @Subtotal</MudText>
                </div>

                <MudDivider DividerType="DividerType.Middle" Class="my-4" />

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Total Due</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary">R @Total</MudText>
                </div>
            </MudPaper>

            <MudCardActions Style="display: flex; justify-content: end; gap: 10px">
                <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Error">Cancel</MudButton>
                <MudButton OnClick="SaveInvoice" Variant="Variant.Outlined" Color="Color.Primary">Save</MudButton>
            </MudCardActions>
        </MudItem>    
    </MudGrid>
</MudContainer>

<style>
    .input-container {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
    }
</style>

@code {
    [Parameter]
    public string? Id { get; set; }
    private bool IsEditMode => !string.IsNullOrWhiteSpace(Id);

    private InvoiceDto Invoice = new()
    {
        Items = new List<InvoiceItemDto>()
    };

    private decimal Subtotal => Invoice.Items.Sum(GetLineTotal);
    private decimal Total => Math.Max(0, Subtotal);

    private CustomerDto? _selectedCustomer;
    private ItemDto? _selectedItem;

    private List<CustomerDto> Customers = new();
    private List<ItemDto> Items = new();

    private static decimal GetLineTotal(InvoiceItemDto item)
    {
        return Math.Max(0, item.Quantity * item.UnitPrice);
    }

    protected override async Task OnInitializedAsync()
    {
        var customers = await _DataService.GetAllAsync<CustomerDto>("customer");
        Customers = customers.Data.ToList();

        var items = await _DataService.GetAllAsync<ItemDto>("item");
        Items = items.Data.ToList();

        if (IsEditMode)
        {
            var invoice = await _DataService.GetByIdAsync<InvoiceDto>("invoice", Id!);
            Invoice = invoice.Data;

            _selectedCustomer = Customers.FirstOrDefault(i => i.CustomerId == invoice.Data.CustomerId);
            StateHasChanged();
        }
    }

    private async Task SaveInvoice()
    {
        if (_selectedCustomer == null)
        {
            await DialogService.ShowMessageBox("Error", "Please select a customer.");
            return;
        }

        Invoice.CustomerId = _selectedCustomer.CustomerId;

        Result response = IsEditMode
            ? await _DataService.PutAsync("invoice", Invoice)
            : await _DataService.PostAsync("invoice", Invoice);

        if (response.IsSuccess)
        {
            await DialogService.ShowMessageBox("Success", "Invoice saved successfully!");
            _NavigationManager.NavigateTo("/invoice/index");
        }
        else
        {
            await DialogService.ShowMessageBox("Error", response.Error?.Description ?? "Unknown error");
        }
    }

    private void AddSelectedItem()
    {
        if (_selectedItem is null)
            return;

        var existing = Invoice.Items.FirstOrDefault(x => x.ItemId == _selectedItem.ItemId);

        if (existing != null)
        {
            // 🔥 If already exists → increase quantity
            existing.Quantity += 1;
        }
        else
        {
            Invoice.Items.Add(new InvoiceItemDto
            {
                ItemId = _selectedItem.ItemId,
                ItemDesc = _selectedItem.ItemDesc,
                UnitPrice = _selectedItem.SellingPrice,
                Quantity = 1
            });
        }

        _selectedItem = null; // reset dropdown
        RecalculateTotals();
    }

    private void RemoveItem(InvoiceItemDto item)
    {
        if (Invoice.Items.Count <= 1)
            return;

        Invoice.Items.Remove(item);
        RecalculateTotals();
    }

    private void RecalculateTotals()
    {
        foreach (var item in Invoice.Items)
        {
            item.Total = item.UnitPrice * item.Quantity;
        }

        Invoice.SubTotal = Invoice.Items.Sum(i => i.Total);
        Invoice.Total = Invoice.SubTotal; // Could add taxes later
    }

    private void Cancel() => _NavigationManager.NavigateTo("/invoice/index");
}
