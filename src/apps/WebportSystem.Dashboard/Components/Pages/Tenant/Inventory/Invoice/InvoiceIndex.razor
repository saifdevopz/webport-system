@page "/invoice/index"
@layout TenantLayout
@attribute [Authorize(Roles = "User")]

<MudText Typo="Typo.h5">Invoices</MudText>

<MudDataGrid Items="@Invoices"
             Filterable="true"
             ColumnResizeMode="ResizeMode.Column"
             Dense="true"
             Hover="true"
             Striped="true"
             QuickFilter="@_quickFilter">
    <ToolBarContent>
        <MudIconButton Href="@($"invoice/modify")" Icon="@Icons.Material.Filled.Add" />
        <MudSpacer />
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="_ => _.InvoiceId" Title="Invoice Id" />
        <PropertyColumn Property="_ => _.InvoiceNumber" Title="Code" />
        <PropertyColumn Property="_ => _.Total" Title="Total" />
        <TemplateColumn CellClass="">
            <CellTemplate>
                <MudStack Row>
                    <MudIconButton OnClick="@(() => DownloadInvoice(context.Item.InvoiceId))" Icon="@Icons.Material.Filled.Print" Color="Color.Dark" />
                    <MudIconButton Href="@($"invoice/modify/{context.Item.InvoiceId}")" Icon="@Icons.Material.Filled.Edit" Color="Color.Success" />
                    <MudIconButton OnClick="@(() => Delete(context.Item.InvoiceId))" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="InvoiceDto" />
    </PagerContent>
</MudDataGrid>

@code {
    private List<InvoiceDto> Invoices = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await GetInvoices();
    }

    private async Task GetInvoices()
    {
        var response = await _DataService.GetAllAsync<InvoiceDto>("invoice");

        if (response.IsSuccess && response.Data != null)
        {
            Invoices = response.Data.ToList();
        }
    }

    private async Task DownloadInvoice(int invoiceId)
    {
        var result = await _DataService.GetFileAsync($"invoice/print?InvoiceId={invoiceId}");

        if (!result.IsSuccess) return;

        var response = result.Data!;

        var stream = await response.Content.ReadAsStreamAsync();

        var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"')
                       ?? $"invoice-{invoiceId}.pdf";

        using var streamRef = new DotNetStreamReference(stream);

        await _IJSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    private async Task Delete(int id)
    {
        var parameters = new DialogParameters<Dialog>
        {
            { _ => _.ContentText, "Do you really want to delete this record? This process cannot be undone." },
            { _ => _.ButtonText, "Delete" },
            { _ => _.Color, Color.Error },
        };

        // Show the dialog and await user response
        var dialog = await DialogService.ShowAsync<Dialog>("Delete", parameters);
        var result = await dialog.Result;

        // Only proceed if user confirms deletion
        if (!result!.Canceled)
        {
            await _DataService.DeleteByIdAsync("invoice", id);
            await GetInvoices();
            await DialogService.ShowMessageBox("Success", "Deleted Successfully");
        }
    }

    private Func<InvoiceDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        return x.InvoiceNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || $"{x.InvoiceId}".Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || $"{x.CustomerId}".Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || $"{x.Total}".Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    };
}

