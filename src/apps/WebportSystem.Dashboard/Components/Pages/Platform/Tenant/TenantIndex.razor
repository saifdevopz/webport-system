@page "/platform/tenant/index"
@layout PlatformLayout

<MudText Typo="Typo.h5">Tenants</MudText>

<MudDataGrid Items="@Tenants"
             Filterable="true"
             ColumnResizeMode="ResizeMode.Column"
             Dense="true"
             Hover="true"
             Striped="true"
             QuickFilter="@_quickFilter">
    <ToolBarContent>
        <MudIconButton Href="@($"category/modify")" Icon="@Icons.Material.Filled.Add" />
        <MudSpacer />
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="_ => _.TenantName" Title="Tenant Name" />
        <PropertyColumn Property="_ => _.DatabaseName" Title="Database Name" />
        <TemplateColumn CellClass="">
            <CellTemplate>
                <MudStack Row>
                    <MudIconButton Href="@($"category/modify/{context.Item.TenantId}")" Icon="@Icons.Material.Filled.Edit" Color="Color.Success" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="CategoryDto" />
    </PagerContent>
</MudDataGrid>

@code {
    private List<TenantDto> Tenants = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await GetTenants();
    }

    private async Task GetTenants()
    {
        var response = await _DataService.GetAllAsync<TenantDto>("tenant");

        if (response.IsSuccess && response.Data != null)
        {
            Tenants = response.Data.ToList();
        }
    }  

    private Func<TenantDto, bool> _quickFilter => _ =>
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        return _.TenantName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || _.DatabaseName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || $"{_.DatabaseName} {_.DatabaseName}".Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    };
}

