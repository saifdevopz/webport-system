@page "/account/login"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 pa-md-10 d-flex flex-column justify-space-between mud-theme-primary rounded-lg" Height="100%">
                <MudStack Spacing="4">
                    <div>
                        <MudText Typo="Typo.overline" Class="mud-text-white">ERP SUITE</MudText>
                        <MudText Typo="Typo.h3" Class="mud-text-white mt-2">Run operations with clarity.</MudText>
                        <MudText Typo="Typo.body1" Class="mud-text-white mt-4">
                            Access finance, inventory, procurement, HR, and reporting from one secure workspace.
                        </MudText>
                    </div>

                    <MudPaper Class="pa-4 rounded-lg mud-theme-surface">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.subtitle1">Why teams choose this ERP</MudText>
                            <MudText Typo="Typo.body2">• Faster approvals and cleaner workflows</MudText>
                            <MudText Typo="Typo.body2">• Secure access for role-based operations</MudText>
                            <MudText Typo="Typo.body2">• Real-time visibility across departments</MudText>
                        </MudStack>
                    </MudPaper>
                </MudStack>

                <MudText Typo="Typo.caption" Class="mud-text-white mt-6">Trusted by operations, finance, and admin teams.</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 pa-md-10 rounded-lg" Outlined="true">
                <MudStack Spacing="4">
                    <div>
                        <MudText Typo="Typo.h4">Welcome back</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">Sign in to continue to your ERP dashboard.</MudText>
                    </div>

                    <MudCard Outlined="true">

                            <EditForm Model="@loginDto" OnValidSubmit="HandleLogin">
                                <DataAnnotationsValidator />
                            <MudCardContent>
                                <MudTextField T="string"
                                              Label="Email"
                                              @bind-Value="loginDto.Email" 
                                              Required="true"
                                              Variant="Variant.Outlined" 
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Mail"
                                              For="@(() => loginDto.Email)" 
                                              />

                                <MudTextField T="string" 
                                              Label="Password"
                                              @bind-Value="loginDto.Password"
                                              Required="true"
                                              Variant="Variant.Outlined" For="@(() => loginDto.Password)" 
                                              InputType="@passwordInput"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@passwordIcon"
                                              OnAdornmentClick="TogglePasswordVisibility"
                                              AdornmentAriaLabel="Toggle password visibility" />
                                <div class="d-flex justify-space-between align-center flex-wrap gap-2">
                                    <MudCheckBox T="bool" @bind-Value="rememberMe" Label="Remember me" Color="Color.Primary" />
                                    <MudLink Href="#" Typo="Typo.body2" Color="Color.Primary" Underline="Underline.Hover">Forgot password?</MudLink>
                                </div>

                                <MudButton ButtonType="ButtonType.Submit"
                                           Disabled="@isLoading"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           Size="Size.Large">

                                    @if (isLoading)
                                    {
                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                                        <MudText Typo="Typo.button">Signing in...</MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.button">Sign in securely</MudText>
                                    }
                                </MudButton>
                            </MudCardContent>
                            </EditForm>
                                                  
                    </MudCard>

                    <MudPaper Class="pa-4 rounded-lg" Outlined="true">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Demo access</MudText>
                            <MudText Typo="Typo.body2">Email: customer1@gmail.com</MudText>
                            <MudText Typo="Typo.body2">Password: 12345678</MudText>
                        </MudStack>
                    </MudPaper>

                    <div class="middle-text">
                        <hr />
                        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                        {
                            <div style="color:red; margin-top: 15px;">
                                <strong>@ErrorMessage</strong>
                            </div>
                        }
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool rememberMe = true;
    private bool showPassword;
    private InputType passwordInput = InputType.Password;
    private string passwordIcon = Icons.Material.Filled.VisibilityOff;

    [CascadingParameter]
    public Task<AuthenticationState>? AuthenticationState { get; set; }

    public string? ErrorMessage { get; set; }
    private bool isLoading = false;
    internal LoginDto loginDto { get; set; } = new();

    private bool _navigated;

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
        passwordInput = showPassword ? InputType.Text : InputType.Password;
        passwordIcon = showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    private async Task HandleLogin()
    {
        isLoading = true;

        try
        {
            var response = await _ITokenService.AccessToken(loginDto);

            if (response.IsSuccess)
            {
                Snackbar.Add(rememberMe ? "Signed in successfully. Session will be remembered." : "Signed in successfully.", Severity.Success);
                _NavigationManager.NavigateTo($"/account/postlogin?Token={response.Data.Token}", forceLoad: true);
            }
            else
            {
                ErrorMessage = response.Error!.Description;
                Snackbar.Add("Invalid credentials. Try the demo account.", Severity.Error);
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override void OnInitialized()
    {
        loginDto.Email = "customer1@gmail.com";
        loginDto.Password = "12345678";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_navigated)
        {
            await CheckUserAuthentication();
            _navigated = true;

            await Task.Delay(200); // wait for browser autofill
            StateHasChanged(); // force MudBlazor to re-evaluate labels
        }
    }

    private async Task CheckUserAuthentication()
    {
        var user = (await AuthenticationState!).User;
        
        if (user?.Identity?.IsAuthenticated == true)
        {
            if (_TenantContext.IsPlatform)
            {
                _NavigationManager.NavigateTo("/platform/dashboard", true);
            }
            else
            {
                _NavigationManager.NavigateTo("/tenant/dashboard", true);
            }
        }
    }
}
