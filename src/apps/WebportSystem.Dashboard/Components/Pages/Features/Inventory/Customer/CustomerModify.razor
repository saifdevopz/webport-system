@page "/customer/modify/{Id?}"
@attribute [Authorize(Roles = "User")]

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <MudCard Elevation="1">
        <MudCardHeader>
            <CardHeaderContent>
                @if (Id == null)
                {
                    <MudText Typo="Typo.h6">Add Customer</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">Update Customer</MudText>
                }
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudTextField @bind-Value="model.Name"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.Name)"
                          Label="Name" />

            <MudTextField @bind-Value="model.Phone"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.Phone)"
                          Label="Phone" />

            <MudTextField @bind-Value="model.Email"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.Email)"
                          Label="Email" />

            <MudTextField @bind-Value="model.CompanyName"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.CompanyName)"
                          Label="CompanyName" />

            <MudTextField @bind-Value="model.AddressLine1"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.AddressLine1)"
                          Label="Address" />

            <MudTextField @bind-Value="model.PostalCode"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.PostalCode)"
                          Label="Postal Code" />

            <MudTextField @bind-Value="model.City"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.City)"
                          Label="City" />

            <MudTextField @bind-Value="model.Province"
                          Required="true"
                          Variant="Variant.Outlined"
                          For="@(() => model.Province)"
                          Label="Province" />
        </MudCardContent>

        <MudCardActions Style="display: flex; justify-content: end; gap: 10px">
            <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Error">Cancel</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Outlined" Color="Color.Primary">Save</MudButton>
        </MudCardActions>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Elevation="0" Variant="Variant.Filled" Dense="true" Class="m-2">
                @ErrorMessage
            </MudAlert>
        }
    </MudCard>
</EditForm>

@code {
    [Parameter] public string? Id { get; set; }
    private bool IsEditMode => !string.IsNullOrWhiteSpace(Id);

    private CustomerDto model = new();
    private string ErrorMessage = string.Empty;

    private static readonly string FeatureName = "customer";

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            try
            {
                model = await GetCustomer();
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to load category: {ex.Message}";
            }
        }
    }

    private async Task<CustomerDto> GetCustomer()
    {
        var response = await _DataService.GetByIdAsync<CustomerDto>(FeatureName, Id!);
        return response.Data!;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            var command = new { customer = model };  

            Result response = IsEditMode
                ? await _DataService.PutAsync(FeatureName, command)
                : await _DataService.PostAsync(FeatureName, command);

            if (response.IsSuccess)
            {
                _NavigationManager.NavigateTo("customer/index");
            }
            else
            {
                ErrorMessage = response.Error?.Description ?? "An unexpected error occurred.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Exception: {ex.Message}";
        }
    }

    private void Cancel() => _NavigationManager.NavigateTo("/customer/index");
}
