@page "/invoice/modify/{Id?}"
@attribute [Authorize(Roles = "User")]

<MudText Typo="Typo.h6">Invoice</MudText>

<div class="input-container">
    <MudSelect T="CustomerDto" @bind-Value="_selectedCustomer" Label="Select Customer">
        @foreach (var customer in Customers)
        {
            <MudSelectItem Value="customer">@customer.Name</MudSelectItem>
        }
    </MudSelect>

    <MudSelect T="ItemDto" @bind-Value="_selectedItem" Label="Select Item">
        @foreach (var item in Items)
        {
            <MudSelectItem T="ItemDto" Value="item">@item.ItemDesc</MudSelectItem>
        }
    </MudSelect>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddSelectedItem">Add Item</MudButton>
</div>

<MudDataGrid Items="@Invoice.Items"
             ColumnResizeMode="ResizeMode.Column"
             Dense="true"
             Hover="true"
             Striped="true">
    <ToolBarContent>
        <MudIconButton Href="@($"category/modify")" Icon="@Icons.Material.Filled.Add" />
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="_ => _.ItemId" Title="Id" />
        <PropertyColumn Property="_ => _.ItemName" Title="Name" />
        <PropertyColumn Property="_ => _.Total" Title="Total" />
        <TemplateColumn>
            <CellTemplate Context="row">
                <MudStack Row>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   OnClick="@(() => RemoveItem(row.Item))" />
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

<MudCardActions Style="display: flex; justify-content: end; gap: 10px">
    <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Error">Cancel</MudButton>
    <MudButton OnClick="SaveInvoice" Variant="Variant.Outlined" Color="Color.Primary">Save</MudButton>
</MudCardActions>

<style>
    .input-container {
        display: flex;
        gap: 20px;
    }
</style>


    @code {
    [Parameter]
    public string? Id { get; set; }
    private bool IsEditMode => !string.IsNullOrWhiteSpace(Id);

    private InvoiceDto Invoice = new()
    {
        Items = new List<InvoiceItemDto>()
    };

    private CustomerDto? _selectedCustomer;
    private ItemDto? _selectedItem;

    private List<CustomerDto> Customers = new();
    private List<ItemDto> Items = new();

    protected override async Task OnInitializedAsync()
    {
        var customers = await _DataService.GetAllAsync<CustomerDto>("customer");
        Customers = customers.Data.Records.ToList();

        var items = await _DataService.GetAllAsync<ItemDto>("item");
        Items = items.Data.Records.ToList();

        if (IsEditMode)
        {
            var invoice = await _DataService.GetByIdAsync<InvoiceDto>("invoice", Id!);
            Invoice = invoice.Data;

            _selectedCustomer = Customers.FirstOrDefault(i => i.CustomerId == invoice.Data.CustomerId);
            StateHasChanged();
        }
    }

    private void AddSelectedItem()
    {
        if (_selectedItem is null)
            return;

        var existing = Invoice.Items.FirstOrDefault(x => x.ItemId == _selectedItem.ItemId);

        if (existing != null)
        {
            // 🔥 If already exists → increase quantity
            existing.Quantity += 1;
        }
        else
        {
            Invoice.Items.Add(new InvoiceItemDto
            {
                ItemId = _selectedItem.ItemId,
                ItemName = _selectedItem.ItemDesc,
                Quantity = 1
            });
        }

        _selectedItem = null; // reset dropdown
        RecalculateTotals();
    }

    private void RemoveItem(InvoiceItemDto item)
    {
        Invoice.Items.Remove(item);
        RecalculateTotals();
    }

    private void RecalculateTotals()
    {
        foreach (var item in Invoice.Items)
        {
            item.Total = item.UnitPrice * item.Quantity;
        }

        Invoice.SubTotal = Invoice.Items.Sum(i => i.Total);
        Invoice.Total = Invoice.SubTotal; // Could add taxes later
    }

    private async Task SaveInvoice()
    {
        if (_selectedCustomer == null)
        {
            await DialogService.ShowMessageBox("Error", "Please select a customer.");
            return;
        }

        Invoice.CustomerId = _selectedCustomer.CustomerId;
        Invoice.InvoiceNumber = GenerateInvoiceNumber();

        Result response = IsEditMode
            ? await _DataService.PutAsync("invoice", Invoice)
            : await _DataService.PostAsync("invoice", Invoice);

        if (response.IsSuccess)
        {
            await DialogService.ShowMessageBox("Success", "Invoice saved successfully!");
            _NavigationManager.NavigateTo("/invoice/index");
        }
        else
        {
            await DialogService.ShowMessageBox("Error", response.Error?.Description ?? "Unknown error");
        }
    }

    private static string GenerateInvoiceNumber()
    {
        var random = new Random();

        var year = DateTime.Now.Year;

        // Random 5-digit number
        var number = random.Next(10000, 99999);

        return $"INV-{year}-{number}";
    }

    private void Cancel() => _NavigationManager.NavigateTo("/invoice/index");

}
